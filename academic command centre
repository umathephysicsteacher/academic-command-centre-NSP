let teacherFilter = 'all';

/* ════════════════════════════════════════════════════
   TIME HELPERS
════════════════════════════════════════════════════ */
function toMins(str){ const [h,m]=str.split(':').map(Number); return h*60+m; }

function getSimPeriodVal(){
  const el = document.getElementById('simPeriod');
  return el ? el.value : 'live';
}
function getSimDayVal(){
  const el = document.getElementById('simDay');
  return el ? parseInt(el.value) : 0;
}

function curPeriod(){
  const sim = getSimPeriodVal();
  if(sim !== 'live'){
    // 'D' for diary
    const nVal = sim === 'D' ? 'D' : parseInt(sim);
    const p = PERIODS.find(x=>x.n===nVal);
    if(p) return {p, pct:0.5};
    return {p:null, label:'Break / Interval'};
  }
  const now = new Date();
  const m = now.getHours()*60 + now.getMinutes();
  // Check breaks first
  for(const b of (typeof BREAKS!=='undefined'?BREAKS:[])){
    const s=toMins(b.start), e=toMins(b.end);
    if(m>=s && m<e) return {p:null, label:b.label, isBreak:true};
  }
  for(const p of PERIODS){
    const s=toMins(p.start), e=toMins(p.end);
    if(m>=s && m<e) return {p, pct:(m-s)/(e-s)};
  }
  const last = toMins(PERIODS[PERIODS.length-1].end);
  const first = toMins(PERIODS[0].start);
  if(m<first) return {p:null, label:'Before School'};
  if(m>=last)  return {p:null, label:'School Dismissed'};
  return {p:null, label:'Break / Interval'};
}

function dayIdx(){
  const sim = getSimPeriodVal();
  if(sim !== 'live') return getSimDayVal();
  const d=new Date().getDay();
  return (d===0||d===6)?0:d-1;
}

/* ════════════════════════════════════════════════════
   CLOCK — runs every second, NO layout thrash
════════════════════════════════════════════════════ */
const clockEl   = document.getElementById('clock');
const datelineEl= document.getElementById('dateline');
const pbPeriodEl= document.getElementById('pbPeriod');
const pbTimeEl  = document.getElementById('pbTime');
const pbFillEl  = document.getElementById('pbFill');
const pbPctEl   = document.getElementById('pbPct');

const MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const WDAYS =['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];

/* Always uses REAL clock — never affected by simulator */
function realCurPeriod(){
  const now = new Date();
  const m = now.getHours()*60 + now.getMinutes();
  for(const b of BREAKS){
    const s=toMins(b.start), e=toMins(b.end);
    if(m>=s && m<e) return {p:null, label:b.label, isBreak:true, start:b.start, end:b.end};
  }
  for(const p of PERIODS){
    const s=toMins(p.start), e=toMins(p.end);
    if(m>=s && m<e) return {p, pct:(m-s)/(e-s)};
  }
  const last  = toMins(PERIODS[PERIODS.length-1].end);
  const first = toMins(PERIODS[0].start);
  if(m < first) return {p:null, label:'School starts at '+PERIODS[0].start, isWaiting:true};
  if(m >= last) return {p:null, label:'School Dismissed · '+PERIODS[PERIODS.length-1].end, isDone:true};
  return {p:null, label:'Break / Interval'};
}

function tick(){
  const now = new Date();

  /* ── Clock ── */
  clockEl.textContent =
    pad(now.getHours())+':'+pad(now.getMinutes())+':'+pad(now.getSeconds());
  datelineEl.textContent =
    WDAYS[now.getDay()]+', '+now.getDate()+' '+MONTHS[now.getMonth()]+' '+now.getFullYear();

  /* ── Period Banner — ALWAYS real time ── */
  const {p, pct, label, isBreak, isWaiting, isDone, start, end} = realCurPeriod();

  if(p){
    /* Active teaching period */
    pbPeriodEl.textContent = p.n==='D' ? '📓 Diary Period' : 'Period '+p.n;
    pbTimeEl.textContent   = p.start+' – '+p.end;
    const pctVal = Math.round((pct||0)*100);
    pbFillEl.style.width   = pctVal+'%';
    pbPctEl.textContent    = pctVal+'%';
    document.querySelector('.period-banner').style.background =
      p.n==='D'
        ? 'linear-gradient(135deg,#7b2fa0 0%,#c8177d 100%)'
        : 'linear-gradient(135deg,#c8177d 0%,#7b2fa0 100%)';
  } else if(isBreak){
    /* Break time */
    pbPeriodEl.textContent = '☕ '+label;
    pbTimeEl.textContent   = (start||'')+' – '+(end||'');
    pbFillEl.style.width   = '100%';
    pbPctEl.textContent    = 'Break';
    document.querySelector('.period-banner').style.background =
      'linear-gradient(135deg,#e8960a 0%,#c8177d 100%)';
  } else if(isWaiting){
    pbPeriodEl.textContent = '🌅 '+label;
    pbTimeEl.textContent   = 'Waiting for school to begin';
    pbFillEl.style.width   = '0%';
    pbPctEl.textContent    = '—';
    document.querySelector('.period-banner').style.background =
      'linear-gradient(135deg,#7b2fa0 0%,#9e1263 100%)';
  } else if(isDone){
    pbPeriodEl.textContent = '🏁 '+label;
    pbTimeEl.textContent   = 'See you tomorrow!';
    pbFillEl.style.width   = '100%';
    pbPctEl.textContent    = 'Done';
    document.querySelector('.period-banner').style.background =
      'linear-gradient(135deg,#555 0%,#333 100%)';
  } else {
    pbPeriodEl.textContent = label||'—';
    pbTimeEl.textContent   = '';
    pbFillEl.style.width   = '0%';
    pbPctEl.textContent    = '—';
  }

  /* Eyebrow label */
  const eyebrow = document.getElementById('pbEyebrow');
  if(eyebrow){
    if(p)        eyebrow.innerHTML = '&#9889; Now Active';
    else if(isBreak)   eyebrow.textContent = '☕ Currently';
    else if(isWaiting) eyebrow.textContent = '⏳ Up Next';
    else if(isDone)    eyebrow.textContent = '✅ Status';
    else               eyebrow.textContent = '⏸ Currently';
  }
}

function pad(n){ return String(n).padStart(2,'0'); }
tick();
setInterval(tick, 1000);

/* ════════════════════════════════════════════════════
   STATUS RESOLVER
════════════════════════════════════════════════════ */
function getStatus(section){
  const {p} = curPeriod();
  const d = dayIdx();
  if(!p) return {subject:'—', teacher:null, room:null, status:'break'};

  const slot = data.schedule[section]?.[d]?.[p.n];
  if(!slot) return {subject:'No Data', teacher:null, room:null, status:'free'};

  const sub = subs.find(s =>
    s.absent===slot.teacher && (s.period==='all'||s.period===String(p.n)));

  if(sub) return {...slot, teacher:sub.substitute, status:'sub', orig:slot.teacher};
  if(!slot.teacher||slot.subject==='Free')
    return {subject:'Free Period', teacher:null, room:null, status:'free'};
  return {...slot, status:'normal'};
}

/* ════════════════════════════════════════════════════
   RENDER DASHBOARD — rebuild only when needed
════════════════════════════════════════════════════ */
let _lastRenderKey = '';

function renderDashboard(force){
  const {p} = curPeriod();
  const renderKey = JSON.stringify({p:p?.n, d:dayIdx(), subs});
  if(!force && renderKey===_lastRenderKey) return;
  _lastRenderKey = renderKey;

  const grid = document.getElementById('sectionGrid');
  grid.innerHTML='';

  let cn=0,cf=0,ca=0;

  data.sections.forEach(sec=>{
    const info = getStatus(sec);
    const sc = info.status==='sub'?'s-sub':info.status==='free'?'s-free':info.status==='normal'?'s-normal':'s-free';
    const bc = info.status==='sub'?'b-sub':info.status==='free'?'b-free':info.status==='normal'?'b-normal':'b-free';
    const bl = info.status==='sub'?'SUB':info.status==='free'?'FREE':info.status==='normal'?'ACTIVE':'FREE';

    if(info.status==='normal'||info.status==='sub') cn++;
    else cf++;

    const ct = CLASS_TEACHERS[sec] || '—';
    const isDiary = info.isDiary || info.subject === 'Diary Period';
    const card = document.createElement('div');
    card.className='sc '+sc+(isDiary?' s-diary':'');
    card.onclick=()=>openModal(sec);
    card.innerHTML=`
      <div class="sc-head">
        <div class="sc-name">Class ${sec}</div>
        <span class="badge ${bc}">${bl}</span>
      </div>
      <div class="sc-subject">${info.subject}${isDiary?' 📓':''}</div>
      ${info.room?`<div class="room-tag">${info.room}</div>`:''}
      <div class="sc-detail">👤 <strong>${info.teacher||'—'}</strong></div>
      ${info.status==='sub'?`<div class="sc-detail" style="color:#2980b9">↩ was: <strong>${info.orig}</strong></div>`:''}
      <div class="sc-detail" style="border-top:1px solid var(--border);margin-top:8px;padding-top:7px;color:var(--purple)">
        🏫 Class Teacher: <strong style="color:var(--purple)">${ct}</strong>
      </div>
    `;
    grid.appendChild(card);
  });

  // Count teacher leisure (teachers NOT assigned to any class this period)
  const {p: cp2} = curPeriod();
  const d2 = dayIdx();
  let teachingNow = new Set();
  if(cp2){
    data.sections.forEach(sec=>{
      const slot = data.schedule[sec]?.[d2]?.[cp2.n];
      if(slot?.teacher) teachingNow.add(slot.teacher);
    });
  }
  const totalTeachers = Object.keys(data.teachers).length;
  const absentTeachers = subs.filter(s => s.period==='all' || (cp2 && s.period===String(cp2.n))).length;
  const teachingCount = teachingNow.size;
  const leisureCount  = totalTeachers - teachingCount - absentTeachers;

  // Needs cover = sections with no teacher (free slot or absent teacher not substituted)
  let needsCover = 0;
  data.sections.forEach(sec=>{
    const info = getStatus(sec);
    if(info.status==='free' && info.subject !== 'Free Period') needsCover++;
    if(info.status==='absent') needsCover++;
  });

  // Needs cover = sections where teacher is absent AND no substitute assigned
  let coverNeeded = 0;
  data.sections.forEach(sec=>{
    const slot = cp2 ? data.schedule[sec]?.[d2]?.[cp2.n] : null;
    if(!slot || !slot.teacher || slot.subject==='Free') return;
    const isAbsent = subs.some(s=>
      s.absent===slot.teacher && (s.period==='all'||(cp2&&s.period===String(cp2.n)))
    );
    const hasSub = subs.some(s=>
      s.absent===slot.teacher &&
      (s.period==='all'||(cp2&&s.period===String(cp2.n))) &&
      s.substitute
    );
    if(isAbsent && !hasSub) coverNeeded++;
  });

  document.getElementById('cntNormal').textContent  = teachingCount;
  document.getElementById('cntLeisure').textContent = Math.max(0, leisureCount);
  document.getElementById('cntAbs').textContent     = absentTeachers;
  document.getElementById('cntCover').textContent   = coverNeeded;
}

/* Dashboard refresh — only rebuild DOM when period changes */
setInterval(()=>{
  if(activeTab==='dashboard') renderDashboard(false);
  if(activeTab==='teachers')  renderTeachers(false);
}, 5000); // every 5s is enough, clock handles second updates

