const BREAKS = [
  { label:'Break', start:'10:20', end:'10:30' },
  { label:'Lunch Break', start:'12:30', end:'13:20' },
];

const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday'];

/* ════════════════════════════════════════════════════
   DEMO DATA
════════════════════════════════════════════════════ */
const TEACHERS = {
  'Mr. Venkat Rao':    'Mathematics',
  'Mrs. Lakshmi':      'Mathematics',
  'Mr. Suresh Kumar':  'Physics',
  'Mrs. Padmavathi':   'Chemistry',
