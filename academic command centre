  'Mrs. Durga':        'Social Studies',
};

// Class Teacher mapping: section -> teacher name
const CLASS_TEACHERS = {
  '6-A':    'Mrs. Sarada Devi',
  '6-B':    'Mrs. Sumitra',
  '7-A':    'Mrs. Vijaya Laxmi',
  '7-B':    'Mrs. Annapurna',
