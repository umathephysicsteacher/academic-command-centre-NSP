function populateSelects(){
  const tList=Object.keys(data.teachers);
  ['selAbsent','selSub'].forEach(id=>{
    const s=document.getElementById(id);
    s.innerHTML='<option value="">Select…</option>';
    tList.forEach(t=>{ const o=document.createElement('option'); o.value=t; o.textContent=t; s.appendChild(o); });
  });
}

function addSub(){
  const a=document.getElementById('selAbsent').value;
  const b=document.getElementById('selSub').value;
  const p=document.getElementById('selPeriod').value;
  if(!a||!b||a===b){ alert('Select two different teachers.'); return; }
  subs.push({absent:a, substitute:b, period:p});
  renderSubList();
  renderDashboard(true);
}

function removeSub(i){
  subs.splice(i,1);
  renderSubList();
  renderDashboard(true);
}

function renderSubList(){
  const list=document.getElementById('subList');
  if(!subs.length){
    list.innerHTML='<div style="color:var(--muted);font-size:0.78rem;padding:12px 0">No substitutions yet.</div>';
