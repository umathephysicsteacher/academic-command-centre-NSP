   TEACHERS VIEW
════════════════════════════════════════════════════ */
function setTeacherFilter(f){
  teacherFilter = f;
  ['all','teaching','free','absent'].forEach(k=>{
    const el=document.getElementById('tf-'+k);
    if(el) el.classList.toggle('active', k===f);
  });
  renderTeachers(true);
}

function renderTeachers(){
  const grid=document.getElementById('teacherGrid');
  grid.innerHTML='';
  const {p}=curPeriod(); const d=dayIdx();
  let shown=0;

  Object.keys(data.teachers).forEach(teacher=>{
    let cls=null;
    if(p){
      data.sections.forEach(sec=>{
        const slot=data.schedule[sec]?.[d]?.[p.n];
        if(slot?.teacher===teacher) cls=sec;
      });
    }
    const isAbsent=subs.some(s=>s.absent===teacher&&(s.period==='all'||(p&&s.period===String(p.n))));
    const status=isAbsent?'absent':cls?'normal':'free';

    // Apply filter
    if(teacherFilter==='teaching' && status!=='normal') return;
    if(teacherFilter==='free'     && status!=='free')   return;
    if(teacherFilter==='absent'   && status!=='absent') return;
    shown++;

    const sc=status==='absent'?'s-absent':status==='free'?'s-free':'s-normal';
    const bc=status==='absent'?'b-absent':status==='free'?'b-free':'b-normal';
    const bl=status==='absent'?'ABSENT':status==='free'?'FREE / LEISURE':'TEACHING';

    const card=document.createElement('div');
    card.className='sc '+sc;
    card.innerHTML=`
      <div class="sc-head">
        <div class="sc-name">${teacher.replace('Mr. ','').replace('Mrs. ','')}</div>
        <span class="badge ${bc}">${bl}</span>
      </div>
      <div class="sc-subject">${data.teachers[teacher]}</div>
      <div class="sc-detail">👤 <strong>${teacher}</strong></div>
      <div class="sc-detail">📍 <strong>${cls?'Class '+cls:status==='absent'?'Absent today':'Free'}</strong></div>
    `;
    grid.appendChild(card);
  });

  const countEl = document.getElementById('tf-count');
  const total = Object.keys(data.teachers).length;
  if(countEl) countEl.textContent = shown === total ? `${total} teachers` : `${shown} of ${total} teachers`;
}

