      <button class="del" onclick="removeSub(${i})">✕</button>
    `;
    list.appendChild(item);
  });
}

/* ════════════════════════════════════════════════════
   XML LOADER
════════════════════════════════════════════════════ */
function loadXML(input){
  const file=input.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const xml=new DOMParser().parseFromString(e.target.result,'text/xml');
      const parsed=parseASC(xml);
      if(parsed){
        data=parsed;
        document.getElementById('xmlStatus').textContent='✓ Loaded: '+file.name;
        document.getElementById('xmlStatus').className='xml-status loaded';
        populateSelects();
        renderDashboard(true);
      }
    }catch(err){
      document.getElementById('xmlStatus').textContent='⚠ Parse error — check XML format.';
    }
  };
  reader.readAsText(file);
}

function parseASC(xml){
  try{
    const teachers={}; const classMap={}; const subjectMap={}; const schedule={};
    xml.querySelectorAll('teacher').forEach(t=>{
      const id=t.getAttribute('id');
      teachers[id]={name:t.getAttribute('name')||t.getAttribute('short')||id,subj:''};
    });
    xml.querySelectorAll('class').forEach(c=>{
      classMap[c.getAttribute('id')]=c.getAttribute('name')||c.getAttribute('short')||c.getAttribute('id');
    });
    xml.querySelectorAll('subject').forEach(s=>{
      subjectMap[s.getAttribute('id')]=s.getAttribute('name')||s.getAttribute('short')||s.getAttribute('id');
    });
    xml.querySelectorAll('lesson,card').forEach(l=>{
      const cid=l.getAttribute('classid')||l.getAttribute('class');
      const tid=l.getAttribute('teacherid')||l.getAttribute('teacher');
      const sid=l.getAttribute('subjectid')||l.getAttribute('subject');
      const day=parseInt(l.getAttribute('day'))-1;
      const per=parseInt(l.getAttribute('period'));
      const room=l.getAttribute('classroom')||l.getAttribute('room')||'';
      if(!cid||isNaN(day)||isNaN(per)) return;
      const sn=classMap[cid]||cid;
      const tn=teachers[tid]?.name||tid||'';
      const subj=subjectMap[sid]||sid||'Unknown';
      if(!schedule[sn]) schedule[sn]={};
      if(!schedule[sn][day]) schedule[sn][day]={};
      schedule[sn][day][per]={subject:subj, teacher:tn, room};
    });
    const tObj={};
    Object.values(teachers).forEach(t=>{ tObj[t.name]=t.subj; });
    return { sections:Object.values(classMap), teachers:tObj, schedule };
  }catch(e){ console.error(e); return null; }
}

/* ════════════════════════════════════════════════════
   PERIOD STRIP
════════════════════════════════════════════════════ */
function renderPeriodStrip(){
  const strip = document.getElementById('periodStrip');
  if(!strip) return;
  /* real = actual school time; selected = simulator choice */
  const {p: realPeriod} = realCurPeriod();
  const sim = getSimPeriodVal();
  const selectedN = sim === 'live' ? realPeriod?.n : (sim==='D'?'D':parseInt(sim));
  const realN = realPeriod?.n;

  strip.innerHTML = '';

  // Build sequence: P1, P2, [Break], P3, P4, P5, [Lunch], P6, P7, [Diary]
  const sequence = [
    {type:'period', n:1},
    {type:'period', n:2},
    {type:'break',  label:'Break', sub:'10:20–10:30'},
    {type:'period', n:3},
    {type:'period', n:4},
    {type:'period', n:5},
    {type:'break',  label:'Lunch', sub:'12:30–1:20'},
    {type:'period', n:6},
    {type:'period', n:7},
    {type:'period', n:'D'},
  ];

  sequence.forEach(item => {
    if(item.type === 'break'){
      const b = document.createElement('div');
      b.className = 'ps-break';
      b.innerHTML = `<div>${item.label}</div><div style="font-size:0.52rem">${item.sub}</div>`;
      strip.appendChild(b);
    } else {
      const p = PERIODS.find(x=>x.n===item.n);
      if(!p) return;
      const el = document.createElement('div');
      const isSelected = p.n === selectedN;
      const isRealNow  = p.n === realN && sim !== 'live';
      el.className = 'ps-item' + (isSelected?' active':'') + (isRealNow?' real-now':'');
      el.innerHTML = `<div class="ps-n">${p.n==='D'?'📓':p.n}</div><div class="ps-t">${p.start}</div>`;
      el.title = p.label + ' · ' + p.start + '–' + p.end;
      el.onclick = ()=>{
        const sel=document.getElementById('simPeriod');
        if(sel){ sel.value=String(p.n); renderDashboard(true); renderPeriodStrip(); }
      };
      el.style.cursor='pointer';
      strip.appendChild(el);
    }
  });
}

/* ════════════════════════════════════════════════════
   TAB SWITCHING
════════════════════════════════════════════════════ */
function switchTab(tab){
  activeTab=tab;
  const tabs=['dashboard','substitutions','teachers'];
  document.querySelectorAll('.nav-tab').forEach((el,i)=>
    el.classList.toggle('active', tabs[i]===tab));
  tabs.forEach(t=>
    document.getElementById('tab-'+t).style.display=t===tab?'block':'none');
  if(tab==='teachers') renderTeachers(true);
}

