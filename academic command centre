<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Samsidh Narsapur – Academic Command Center</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --pink:      #c8177d;
    --pink-dark: #9e1263;
    --pink-light:#f0d0e8;
    --purple:    #7b2fa0;
    --gold:      #e8960a;
    --bg:        #ffffff;
    --surface:   #fdf6fb;
    --surface2:  #f8eef6;
    --border:    #ead5e8;
    --text:      #1a0d18;
    --muted:     #8a607e;
    --serif:     'Playfair Display', Georgia, serif;
    --sans:      'DM Sans', sans-serif;
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
  }

  /* ── HEADER ─────────────────────────────────── */
  header {
    background: #fff;
    border-bottom: 2px solid var(--pink-light);
    position: sticky; top:0; z-index:100;
    box-shadow: 0 2px 12px rgba(200,23,125,0.08);
  }

  .header-inner {
    max-width: 1400px; margin:0 auto;
    padding: 10px 24px;
    display: flex; align-items: center; justify-content: space-between; gap:16px;
  }

  .brand {
    display: flex; align-items: center; gap:14px;
  }

  .brand-logo {
    width:52px; height:52px; border-radius:50%;
    border:2px solid var(--pink-light);
    overflow:hidden; background:#fff;
    display:flex; align-items:center; justify-content:center;
  }

  .brand-logo img { width:100%; height:100%; object-fit:contain; }

  .brand-text {}
  .brand-name {
    font-family: var(--serif);
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--pink);
    letter-spacing: -0.5px;
    line-height:1;
  }

  .brand-sub {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--purple);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top:3px;
  }

  .header-right {
    display:flex; align-items:center; gap:20px;
  }

  .clock-box {
    text-align:right;
  }

  .live-clock {
    font-family: var(--serif);
    font-size:1.7rem;
    font-weight:700;
    color: var(--pink);
    line-height:1;
    letter-spacing:1px;
  }

  .live-date {
    font-size:0.68rem;
    color: var(--muted);
    margin-top:3px;
    font-weight:500;
    letter-spacing:0.5px;
  }

  .pulse {
    width:9px; height:9px;
    background: #2ecc71;
    border-radius:50%;
    flex-shrink:0;
    box-shadow: 0 0 0 0 rgba(46,204,113,0.4);
    animation: livepulse 2s infinite;
  }

  @keyframes livepulse {
    0%   { box-shadow: 0 0 0 0   rgba(46,204,113,0.5); }
    70%  { box-shadow: 0 0 0 8px rgba(46,204,113,0); }
    100% { box-shadow: 0 0 0 0   rgba(46,204,113,0); }
  }

  /* ── MAIN WRAP ────────────────────────────── */
  .wrap { max-width:1400px; margin:0 auto; padding:20px 24px 40px; }

  /* ── PERIOD BANNER ───────────────────────── */
  .period-banner {
    background: linear-gradient(135deg, var(--pink) 0%, var(--purple) 100%);
    border-radius:14px;
    padding:18px 24px;
    display:flex; align-items:center; justify-content:space-between;
    gap:20px; flex-wrap:wrap;
    margin-bottom:18px;
    box-shadow: 0 4px 20px rgba(200,23,125,0.25);
  }

  .pb-left {}
  .pb-eyebrow {
    font-size:0.65rem; font-weight:600; letter-spacing:3px;
    text-transform:uppercase; color:rgba(255,255,255,0.7);
    margin-bottom:4px;
  }

  .pb-period {
    font-family: var(--serif);
    font-size:1.7rem; font-weight:800; color:#fff; line-height:1;
  }

  .pb-time {
    font-size:0.78rem; color:rgba(255,255,255,0.75); margin-top:4px; font-weight:500;
  }

  .pb-progress { flex:1; min-width:180px; }
  .pb-prog-row {
    display:flex; justify-content:space-between;
    font-size:0.65rem; color:rgba(255,255,255,0.7);
    margin-bottom:7px; font-weight:500;
  }

  .prog-track {
    height:5px; background:rgba(255,255,255,0.2); border-radius:3px; overflow:hidden;
  }

  .prog-fill {
    height:100%; background:#fff; border-radius:3px;
    transition: width 1s linear;
  }

  .pb-stats {
    display:flex; gap:10px; flex-wrap:wrap;
  }

  .stat-pill {
    background:rgba(255,255,255,0.15);
    border:1px solid rgba(255,255,255,0.25);
    border-radius:20px;
    padding:6px 14px;
    color:#fff;
    font-size:0.75rem;
    font-weight:600;
    display:flex; align-items:center; gap:6px;
  }

  .stat-pill .n { font-family:var(--serif); font-size:1.1rem; font-weight:700; }
  .stat-pill.red   { background:rgba(231,76,60,0.35);  border-color:rgba(231,76,60,0.5); }
  .stat-pill.amber { background:rgba(243,156,18,0.35); border-color:rgba(243,156,18,0.5); }
  .stat-pill.green { background:rgba(46,204,113,0.25); border-color:rgba(46,204,113,0.5); }
  .stat-pill.blue  { background:rgba(52,152,219,0.25); border-color:rgba(52,152,219,0.5); }

  /* ── TOOLBAR ─────────────────────────────── */
  .toolbar {
    display:flex; align-items:center; gap:12px; margin-bottom:18px; flex-wrap:wrap;
  }

  .nav-tabs {
    display:flex; gap:3px;
    background: var(--surface2);
    border:1px solid var(--border);
    border-radius:10px; padding:4px;
  }

  .nav-tab {
    padding:7px 16px; border-radius:7px; border:none;
    background:none; color:var(--muted);
    font-family:var(--sans); font-size:0.82rem; font-weight:600;
    cursor:pointer; transition:all 0.18s;
  }

  .nav-tab.active {
    background: var(--pink);
    color:#fff;
    box-shadow:0 2px 8px rgba(200,23,125,0.3);
  }

  .upload-btn {
    display:flex; align-items:center; gap:7px;
    padding:8px 16px;
    background:#fff;
    border:1.5px dashed var(--pink);
    border-radius:8px;
    color:var(--pink);
    font-family:var(--sans);
    font-size:0.75rem; font-weight:600;
    cursor:pointer; transition:background 0.15s;
  }

  .upload-btn:hover { background:var(--surface2); }
  .upload-btn input { display:none; }

  .xml-status {
    font-size:0.7rem; color:var(--muted); font-weight:500;
  }

  .xml-status.loaded { color:#2ecc71; }

  .day-label {
    margin-left:auto;
    background:var(--surface2);
    border:1px solid var(--border);
    border-radius:8px;
    padding:6px 14px;
    font-size:0.72rem; font-weight:600; color:var(--purple);
  }

  /* ── SECTION GRID ────────────────────────── */
  .section-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(265px,1fr));
    gap:12px;
  }

  .sc {
    background:#fff;
    border:1.5px solid var(--border);
    border-radius:12px;
    padding:15px 16px;
    cursor:pointer;
    position:relative;
    overflow:hidden;
    transition: box-shadow 0.18s, border-color 0.18s, transform 0.18s;
  }

  .sc::before {
    content:'';
    position:absolute; left:0; top:0; bottom:0; width:4px;
    border-radius:4px 0 0 4px;
  }

  .sc.s-normal  { border-color:#d4edda; }
  .sc.s-normal::before  { background:#27ae60; }
  .sc.s-free    { border-color:#fdeaa7; }
  .sc.s-free::before    { background:var(--gold); }
  .sc.s-sub     { border-color:#d0e4ff; }
  .sc.s-sub::before     { background:#2980b9; }
  .sc.s-absent  { border-color:#fcd0cc; }
  .sc.s-absent::before  { background:#e74c3c; }

  .sc:hover {
    transform:translateY(-2px);
    box-shadow:0 6px 20px rgba(200,23,125,0.12);
    border-color:var(--pink-light);
  }

  .sc-head {
    display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;
  }

  .sc-name {
    font-family:var(--serif);
    font-size:1.05rem; font-weight:700; color:var(--pink-dark);
  }

  .badge {
    font-size:0.58rem; font-weight:700; letter-spacing:1px;
    text-transform:uppercase; padding:3px 8px; border-radius:4px;
  }

  .b-normal { background:#eafaf1; color:#27ae60; }
  .b-free   { background:#fef9e7; color:#d68910; }
  .b-sub    { background:#ebf5fb; color:#2980b9; }
  .b-absent { background:#fdf2f2; color:#e74c3c; }

  .sc-subject {
    font-size:0.95rem; font-weight:700; color:var(--text); margin-bottom:5px;
  }

  .sc-detail {
    font-size:0.72rem; color:var(--muted); display:flex; align-items:center; gap:5px;
    margin-top:3px; font-weight:500;
  }

  .sc-detail strong { color:var(--text); }

  .room-tag {
    position:absolute; top:13px; right:14px;
    font-size:0.62rem; color:var(--muted);
    background:var(--surface2);
    border:1px solid var(--border);
    padding:2px 7px; border-radius:4px; font-weight:500;
  }

  /* ── SUBSTITUTION TAB ────────────────────── */
  .sub-form {
    background:var(--surface);
    border:1.5px solid var(--border);
    border-radius:12px;
    padding:20px; margin-bottom:18px;
  }

  .sub-form h3 {
    font-family:var(--serif); font-size:1.05rem; font-weight:700;
    color:var(--pink-dark); margin-bottom:16px;
  }

  .form-row {
    display:grid; grid-template-columns:1fr 1fr 1fr auto; gap:10px; align-items:end;
  }

  .fg label {
    display:block; font-size:0.65rem; font-weight:600; letter-spacing:1px;
    text-transform:uppercase; color:var(--muted); margin-bottom:5px;
  }

  .fg select, .fg input {
    width:100%;
    background:#fff; border:1.5px solid var(--border); border-radius:8px;
    padding:8px 12px; color:var(--text);
    font-family:var(--sans); font-size:0.85rem; outline:none;
    transition:border-color 0.15s;
  }

  .fg select:focus, .fg input:focus { border-color:var(--pink); }

  .add-btn {
    padding:9px 20px; background:var(--pink); color:#fff;
    border:none; border-radius:8px; font-family:var(--sans);
    font-weight:700; font-size:0.85rem; cursor:pointer;
    transition:background 0.15s;
    box-shadow:0 2px 8px rgba(200,23,125,0.3);
  }

  .add-btn:hover { background:var(--pink-dark); }

  .section-title-label {
    font-size:0.68rem; font-weight:700; letter-spacing:2.5px;
    text-transform:uppercase; color:var(--muted); margin-bottom:10px;
  }

  .sub-list { display:flex; flex-direction:column; gap:8px; }

  .sub-item {
    display:flex; align-items:center; gap:10px;
    background:#fff; border:1.5px solid #d0e4ff;
    border-radius:8px; padding:10px 14px;
    font-size:0.82rem; font-weight:500;
  }

  .sub-item .arr { color:#2980b9; }
  .sub-item .del {
    margin-left:auto; background:none; border:none;
    color:#e74c3c; cursor:pointer; font-size:0.9rem; font-weight:700;
  }

  /* ── TEACHERS TAB ────────────────────────── */
  /* reuses .section-grid + .sc */

  /* ── MODAL ───────────────────────────────── */
  .modal-overlay {
    position:fixed; inset:0;
    background:rgba(26,13,24,0.55);
    backdrop-filter:blur(5px);
    z-index:200; display:none;
    align-items:center; justify-content:center; padding:24px;
  }

  .modal-overlay.open { display:flex; }

  .modal {
    background:#fff;
    border:1.5px solid var(--border);
    border-radius:16px;
    width:100%; max-width:820px; max-height:88vh;
    overflow:auto; padding:28px;
    box-shadow:0 20px 60px rgba(200,23,125,0.15);
  }

  .modal-head {
    display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:22px;
  }

  .modal-title {
    font-family:var(--serif); font-size:1.5rem; font-weight:800; color:var(--pink-dark);
  }

  .modal-sub {
    font-size:0.68rem; color:var(--muted); letter-spacing:2px; text-transform:uppercase; margin-top:4px;
  }

  .close-btn {
    background:var(--surface2); border:1.5px solid var(--border); color:var(--muted);
    width:32px; height:32px; border-radius:8px; cursor:pointer;
    font-size:1rem; display:flex; align-items:center; justify-content:center;
  }

  .tt-grid {
    display:grid;
    grid-template-columns:70px repeat(5,1fr);
    gap:4px;
  }

  .tg-h {
    background:var(--pink); color:#fff;
    border-radius:6px; padding:7px 6px;
    font-size:0.63rem; font-weight:700;
    letter-spacing:1px; text-align:center; text-transform:uppercase;
  }

  .tg-pl {
    background:var(--surface2); border-radius:6px; padding:8px 6px;
    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;
    font-size:0.62rem; font-weight:600; color:var(--muted);
  }

  .tg-cell {
    background:var(--surface);
    border:1px solid var(--border);
    border-radius:6px; padding:7px 8px;
    font-size:0.72rem; transition:border-color 0.15s;
  }

  .tg-cell.cur { border-color:var(--pink); background:#fff0f8; }
  .tg-cell .s { font-weight:700; font-size:0.78rem; color:var(--text); }
  .tg-cell .t { font-size:0.62rem; color:var(--muted); margin-top:2px; }

  /* ── EMPTY STATE ──────────────────────────── */
  .empty {
    text-align:center; padding:50px 20px; color:var(--muted);
  }

  .empty .eicon { font-size:2.5rem; margin-bottom:12px; }
  .empty h3 { font-family:var(--serif); color:var(--pink-dark); margin-bottom:8px; }
  .empty p  { font-size:0.78rem; line-height:1.7; }

  /* ── RESPONSIVE ───────────────────────────── */
  @media(max-width:640px){
    .form-row { grid-template-columns:1fr 1fr; }
    .pb-stats  { gap:6px; }
    .brand-name { font-size:1.2rem; }
    .live-clock { font-size:1.3rem; }
  }

  /* No flicker: no CSS animations on main content */
  .sc { will-change:transform; }

  /* Teacher filter buttons */
  .tf-btn {
    padding: 7px 16px; border-radius: 20px;
    border: 1.5px solid var(--border);
    background: #fff; color: var(--muted);
    font-family: var(--sans); font-size: 0.78rem; font-weight: 600;
    cursor: pointer; transition: all 0.18s;
  }
  .tf-btn:hover { border-color: var(--pink); color: var(--pink); }
  .tf-btn.active { background: var(--pink); color: #fff; border-color: var(--pink); box-shadow: 0 2px 8px rgba(200,23,125,0.25); }

  /* Diary period card */
  .sc.s-diary::before { background: var(--purple); }
  .sc.s-diary { border-color: #e2d0f0; }

  /* Break banner state */
  .period-banner.is-break {
    background: linear-gradient(135deg, #e8960a 0%, #c8177d 100%);
  }

  /* Period schedule strip below header */
  .period-strip {
    display: flex; gap: 0; overflow-x: auto;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; margin-bottom: 16px;
    padding: 6px 8px; align-items: center;
  }

  .ps-item {
    display: flex; flex-direction: column; align-items: center;
    padding: 5px 10px; border-radius: 7px; min-width: 80px;
    font-size: 0.65rem; font-weight: 600; text-align: center;
    flex-shrink: 0; cursor: default; transition: background 0.15s;
  }

  .ps-item.active {
    background: var(--pink); color: #fff;
  }

  .ps-item .ps-n { font-family: var(--serif); font-size: 0.85rem; font-weight: 700; }
  .ps-item .ps-t { color: var(--muted); margin-top: 1px; font-size: 0.6rem; }
  .ps-item.active .ps-t { color: rgba(255,255,255,0.75); }

  /* Real current period indicator on strip */
  .ps-item.real-now {
    outline: 2px solid var(--pink);
    outline-offset: -2px;
  }
  .ps-item.real-now .ps-t::after {
    content: ' ●';
    color: #2ecc71;
    font-size: 0.55rem;
  }

  .ps-break {
    width: 28px; text-align: center; font-size: 0.6rem;
    color: var(--muted); flex-shrink: 0; font-weight: 600;
  }
</style>
</head>
<body>

<!-- ══ HEADER ══════════════════════════════════════ -->
<header>
  <div class="header-inner">
    <div class="brand">
      <div class="brand-logo">
        <img src="/mnt/user-data/uploads/samsidh_logo.png" alt="Samsidh" onerror="this.style.display='none';this.parentNode.innerHTML='🌸'">
      </div>
      <div class="brand-text">
        <div class="brand-name">Samsidh</div>
        <div class="brand-sub">Academic Command Center · Narsapur</div>
      </div>
    </div>
    <div class="header-right">
      <div class="pulse"></div>
      <div class="clock-box">
        <div class="live-clock" id="clock">--:--:--</div>
        <div class="live-date"  id="dateline">Loading…</div>
      </div>
    </div>
  </div>
</header>

<!-- ══ MAIN ════════════════════════════════════════ -->
<div class="wrap">

  <!-- Period Banner -->
  <div class="period-banner">
    <div class="pb-left">
      <div class="pb-eyebrow">⚡ Now Active</div>
      <div class="pb-period" id="pbPeriod">—</div>
      <div class="pb-time"   id="pbTime">—</div>
    </div>
    <div class="pb-progress">
      <div class="pb-prog-row">
        <span>Period Progress</span>
        <span id="pbPct">—</span>
      </div>
      <div class="prog-track">
        <div class="prog-fill" id="pbFill" style="width:0%"></div>
      </div>
    </div>
    <div class="pb-stats">
      <div class="stat-pill green"><span class="n" id="cntNormal">0</span> Teaching</div>
      <div class="stat-pill amber"><span class="n" id="cntLeisure">0</span> In Leisure</div>
      <div class="stat-pill red"><span class="n" id="cntAbs">0</span> Absent</div>
      <div class="stat-pill blue"><span class="n" id="cntCover">0</span> Needs Cover</div>
    </div>
  </div>

  <!-- Period Strip -->
  <div class="period-strip" id="periodStrip"></div>

  <!-- Toolbar -->
  <div class="toolbar">
    <div class="nav-tabs">
      <button class="nav-tab active" onclick="switchTab('dashboard')">📊 Dashboard</button>
      <button class="nav-tab"        onclick="switchTab('substitutions')">🔄 Substitutions</button>
      <button class="nav-tab"        onclick="switchTab('teachers')">👨‍🏫 Teachers</button>
    </div>
    <label class="upload-btn">
      📁 Upload ASC XML
      <input type="file" accept=".xml" onchange="loadXML(this)">
    </label>
    <div class="xml-status" id="xmlStatus">Demo data · upload your ASC XML to begin</div>
    <div style="display:flex;align-items:center;gap:8px;margin-left:auto;">
      <label style="font-size:0.68rem;font-weight:600;color:var(--muted);white-space:nowrap;">Simulate:</label>
      <select id="simDay" onchange="renderDashboard(true)" style="background:#fff;border:1.5px solid var(--border);border-radius:7px;padding:5px 10px;font-family:var(--sans);font-size:0.78rem;color:var(--text);outline:none;cursor:pointer;">
        <option value="0">Monday</option>
        <option value="1">Tuesday</option>
        <option value="2">Wednesday</option>
        <option value="3">Thursday</option>
        <option value="4">Friday</option>
      </select>
      <select id="simPeriod" onchange="renderDashboard(true);renderPeriodStrip();" style="background:#fff;border:1.5px solid var(--border);border-radius:7px;padding:5px 10px;font-family:var(--sans);font-size:0.78rem;color:var(--text);outline:none;cursor:pointer;">
        <option value="live">&#9889; Live Time</option>
        <option value="1">Period 1 &nbsp;09:00–09:40</option>
        <option value="2">Period 2 &nbsp;09:40–10:20</option>
        <option value="3">Period 3 &nbsp;10:30–11:10</option>
        <option value="4">Period 4 &nbsp;11:10–11:50</option>
        <option value="5">Period 5 &nbsp;11:50–12:30</option>
        <option value="6">Period 6 &nbsp;13:20–14:05</option>
        <option value="7">Period 7 &nbsp;14:05–14:50</option>
        <option value="D">Diary Period  14:50–15:45</option>
      </select>
    </div>
  </div>

  <!-- ── TAB: DASHBOARD ── -->
  <div id="tab-dashboard">
    <div class="section-grid" id="sectionGrid"></div>
  </div>

  <!-- ── TAB: SUBSTITUTIONS ── -->
  <div id="tab-substitutions" style="display:none">
    <div class="sub-form">
      <h3>Mark Teacher Absent & Assign Substitute</h3>
      <div class="form-row">
        <div class="fg">
          <label>Absent Teacher</label>
          <select id="selAbsent"><option value="">Select…</option></select>
        </div>
        <div class="fg">
          <label>Substitute</label>
          <select id="selSub"><option value="">Select…</option></select>
        </div>
        <div class="fg">
          <label>Period</label>
          <select id="selPeriod">
            <option value="all">All Periods</option>
            <option value="1">Period 1</option><option value="2">Period 2</option>
            <option value="3">Period 3</option><option value="4">Period 4</option>
            <option value="5">Period 5</option><option value="6">Period 6</option>
            <option value="7">Period 7</option><option value="D">Diary Period</option>
          </select>
