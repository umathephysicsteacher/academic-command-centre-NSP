<script>
/* ════════════════════════════════════════════════════
   CONFIG  — adjust to match Samsidh school timings
════════════════════════════════════════════════════ */
const PERIODS = [
  { n:1, start:'09:00', end:'09:40', label:'Period 1' },
  { n:2, start:'09:40', end:'10:20', label:'Period 2' },
  // Break 10:20–10:30
